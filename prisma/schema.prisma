generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Users {
  id                String              @id @default(uuid())
  email             String              @unique
  firstName         String?
  lastName          String?
  phone             String?
  profilePicture    String?
  bio               String?
  company           String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  userAuths         UserAuths?
  UserVerifications UserVerifications[]
  UserTokens        UserTokens?
}

model UserAuths {
  id                String   @id @default(uuid())
  userId            String   @unique
  passwordHash     String
  recognisedDevices String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              Users    @relation(fields: [userId], references: [id])
}

model UserVerifications {
  id        String   @id @default(uuid())
  userId    String
  token     String
  deviceId  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      Users    @relation(fields: [userId], references: [id])
}

model UserTokens {
  id           String   @id @default(uuid())
  userId       String @unique
  resetPasswordToken     String?
  resetPasswordExpires   DateTime?
  refreshToken String
  accessToken  String
  deviceId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         Users    @relation(fields: [userId], references: [id])
}
