generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id                String              @id @default(uuid())
  email             String              @unique
  firstName         String?
  lastName          String?
  phone             String?        
  company           String?        
  profilePicture    String?        
  bio               String?        
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  UserAuths         UserAuths[]
  UserVerifications UserVerifications[]
  UserTokens        UserTokens[]
}

model UserAuths {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         Users    @relation(fields: [userId], references: [id])
}

model UserVerifications {
  id        String   @id @default(uuid())
  userId    String
  token     String   // For device verification OTP
  resetPasswordOTP     String?   // For password reset OTP
  resetPasswordExpires DateTime? // Expiry for reset OTP
  deviceId  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      Users    @relation(fields: [userId], references: [id])
}

model UserTokens {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  accessToken  String
  deviceId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         Users    @relation(fields: [userId], references: [id])
}